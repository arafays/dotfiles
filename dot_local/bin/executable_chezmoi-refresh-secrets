#!/bin/bash
# chezmoi-refresh-secrets — Cache Bitwarden secrets to .chezmoidata/secrets.yaml
#
# Fetches API keys from Bitwarden and writes them to a data file so that
# chezmoi templates can reference them without unlocking the vault on every
# apply. Run this after changing secrets in Bitwarden.
#
# Usage: chezmoi-refresh-secrets

set -euo pipefail

# Locate chezmoi source directory
SOURCE_DIR="$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi")"
DATA_DIR="$SOURCE_DIR/.chezmoidata"
DATA_FILE="$DATA_DIR/secrets.yaml"

mkdir -p "$DATA_DIR"

# ── Bitwarden unlock ──────────────────────────────────────────────
if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  echo "Unlocking Bitwarden vault..."
  BW_SESSION="$(bw unlock --raw)"
  export BW_SESSION
fi

# ── Fetch secrets ─────────────────────────────────────────────────
echo "→ Fetching CONTEXT7_API_KEY..."
context7_api_key="$(bw get item "Context7 API Key" | jq -r '.notes')"

echo "→ Fetching EXA_API_KEY..."
exa_api_key="$(bw get item "EXA API Key" | jq -r '.notes')"

# ── Write cache ───────────────────────────────────────────────────
cat > "$DATA_FILE" << SECRETS_EOF
# Cached secrets — auto-generated by chezmoi-refresh-secrets
# Edit Bitwarden, re-run \`chezmoi-refresh-secrets\`, then \`chezmoi apply\`.
secrets:
  context7_api_key: ${context7_api_key@Q}
  exa_api_key: ${exa_api_key@Q}
SECRETS_EOF

echo "✓ Secrets cached to $DATA_FILE"
echo "→ Run 'chezmoi apply' to use updated values."

