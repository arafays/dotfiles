{
	"output": "DP-1",
	"layer": "top",
	"position": "top",
	"spacing": 5,

	"modules-left": [
		"hyprland/workspaces",
		"custom/platform-profile",
		"cpu",
		"memory"
	],
	"modules-center": ["clock"],
	"modules-right": ["wireplumber", "hyprland/language", "network", "tray"],

	"cpu": {
		"format": "\uf2db  {usage}% ",
		"interval": 5,
		"format-icons": {
			"0-20": "\uf2db",
			"20-40": "\uf85a",
			"40-60": "\uf85b",
			"60-80": "\uf85c",
			"80-100": "\uf2c7"
		}
	},

	"memory": {
		"interval": 30,
		"format": "\uf538  {used:0.1f}G"
	},

	"temperature": {
		"format": "\uf2c9 {temperatureC}°C"
	},

	"hyprland/workspaces": {
		"format": "{icon}",
		"on-click": "activate",
		"format-icons": {
			"1": "",
			"2": "",
			"3": "",
			"4": "",
			"5": "",
			"urgent": "",
			"active": "",
			"default": ""
		},
		"icon-size": 10,
		"sort-by-number": true,
		"persistent-workspaces": {
			"1": [],
			"2": [],
			"3": [],
			"4": [],
			"5": []
		}
	},

	"clock": {
		"format": "{:%d.%m.%Y | %H:%M}"
	},

	"wireplumber": {
		"format": "\uf028  {volume}%",
		"max-volume": 100,
		"scroll-step": 5
	},

	"network": {
		"format": "",
		"format-ethernet": "\uf6ff",
		"format-wifi": "{icon}",
		"format-disconnected": "\uf127",
		"format-icons": ["\uf1eb", "\uf1eb", "\uf1eb", "\uf1eb", "\uf1eb"],
		"tooltip-format-wifi": "{essid} ({signalStrength}%)",
		"tooltip-format-ethernet": "{ifname}",
		"tooltip-format-disconnected": "Disconnected"
	},

	"tray": {
		"icon-size": 16,
		"spacing": 16
	},

	"custom/platform-profile": {
		"format": "{icon} ",
		"exec": "~/.config/waybar/platform_profile.sh",
		"return-type": "json",
		"restart-interval": 1,
		"format-icons": {
			"quiet": "\uf023",
			"balanced": "\uf0e7",
			"performance": "\uf2c7",
			"default": "\uf059"
		}
	},

	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "\uf186",
			"deactivated": "\uf185"
		}
	}
}
