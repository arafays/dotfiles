# Ref https://wiki.hypr.land/Configuring/Workspace-Rules/
# "Smart gaps" / "No gaps when only"
# uncomment all if you wish to use that.
# workspace = w[tv1], gapsout:0, gapsin:0
# workspace = f[1], gapsout:0, gapsin:0
# windowrulev2 = bordersize 0, floating:0, onworkspace:w[tv1]
# windowrulev2 = rounding 0, floating:0, onworkspace:w[tv1]
# windowrulev2 = bordersize 0, floating:0, onworkspace:f[1]
# windowrulev2 = rounding 0, floating:0, onworkspace:f[1]

##############################
### WINDOWS AND WORKSPACES ###
##############################

# See https://wiki.hypr.land/Configuring/Window-Rules/ for more
# See https://wiki.hypr.land/Configuring/Workspace-Rules/ for workspace rules

# Example windowrule
# windowrulev2 = float,class:^(kitty)$,title:^(kitty)$

# General Rules
windowrulev2 = suppressevent maximize, class:.*
windowrulev2 = nofocus,class:^$,title:^$,xwayland:1,floating:1,fullscreen:0,pinned:0
layerrule = noanim, selection

# Fullscreen screensaver
windowrulev2 = fullscreen, class:Screensaver

# No border for floating xwayland windows (e.g. context menus)
windowrulev2 = bordersize 0, xwayland:1, floating:1
windowrulev2 = noblur,class:^()$,title:^()$
windowrulev2 = noblur, class:^(), title:(Open.*Files?|Open [F|f]older.*|Save.*Files?|Save.*As|Save|All Files)

# Floating Windows
windowrulev2 = float, tag:floating-window
windowrulev2 = center, tag:floating-window
windowrulev2 = size 800 600, tag:floating-window
windowrulev2 = tag +floating-window, class:(blueberry.py|Impala|Wiremix|org.gnome.NautilusPreviewer|com.gabm.satty|About|TUI.float|org.kde.dolphin)
windowrulev2 = tag +floating-window, class:(xdg-desktop-portal-gtk|sublime_text|DesktopEditors|org.gnome.Nautilus|), title:^(Open.*Files?|Open [F|f]older.*|Save.*Files?|Save.*As|Save|All Files)

# Common Modals
windowrulev2 = float,title:^(Open Files)$
windowrulev2 = float,title:^(Open)$
windowrulev2 = float,title:^(Choose Files)$
windowrulev2 = float,title:^(Save As)$
windowrulev2 = float,title:^(Confirm to replace files)$
windowrulev2 = float,title:^(File Operation Progress)$
windowrulev2 = float,class:^(xdg-desktop-portal-gtk)$
windowrulev2 = noblur, class:^(xdg-desktop-portal-gtk)

# Application Specific Rules

# VLC Media Player
windowrulev2 = float,class:^(vlc)$
windowrulev2 = float,class:^(vlc)$,title:^(Preferences)$
windowrulev2 = float,class:^(vlc)$,title:^(Simple Preferences)$
windowrulev2 = float,class:^(vlc)$,title:^(Open Media)$

# No transparency on media windows
windowrulev2 = opacity 1 1, class:^(zoom|vlc|mpv|org.kde.kdenlive|com.obsproject.Studio|com.github.PintaProject.Pinta|imv|org.gnome.NautilusPreviewer|org.kde.dolphin)$

# Steam
windowrulev2 = opacity 1 1,class:^([Ss]team)$
windowrulev2 = opacity 1 1,class:^(steamwebhelper)$

# Dolphin
windowrulev2 = noblur,class:^dolphin$
windowrulev2 = float,class:^dolphin$,title:^(Progress Dialog — Dolphin)$
windowrulev2 = float,class:^dolphin$,title:^(Copying — Dolphin)$

# Firefox
windowrulev2 = float,title:^(About Mozilla Firefox)$
windowrulev2 = float,class:^(firefox)$,title:^(Picture-in-Picture)$
windowrulev2 = float,class:^(firefox)$,title:^(Firefox — Sharing Indicator)$
windowrulev2 = float,class:^(firefox)$,title:^(Save As)$
windowrulev2 = float,class:^(firefox)$,title:^(Open File)$
windowrulev2 = float,class:^(firefox)$,title:^(Library)$

# Bitwarden
windowrulev2 = noscreenshare, class:^(Bitwarden)$
windowrulev2 = float,class:^(Bitwarden),title:^([Bb]itwarden)$
windowrulev2 = float, title:(.*(Sign in|Unlock).*)
windowrulev2 = center, title:(.*(Sign in|Unlock).*)
windowrulev2 = float, title:(.*Bitwarden.*)
windowrulev2 = center, title:(.*Bitwarden.*)
windowrulev2 = float,title:(.*Extension.*)
windowrulev2 = center, title:(.*Extension.*)

# Zen Browser
windowrulev2 = opacity 1 1,class:^([zZ]en)$
windowrulev2 = bordersize 0,class:^([zZ]en)$
windowrulev2 = float,title:^(About Zen Browser)$
windowrulev2 = float,class:^([zZ]en)$,title:^(Picture-in-Picture)$
windowrulev2 = float,class:^([zZ]en)$,title:^(Library)$
windowrulev2 = float, class:^([zZ]en)$, title:(.*([Bb]itwarden|Sign in|Unlock).*)
windowrulev2 = center, class:^([zZ]en)$, title:(.*([Bb]itwarden|Sign in|Unlock).*)
windowrulev2 = size 800 600, class:^([zZ]en)$, title:(.*([Bb]itwarden|Sign in|Unlock).*) 
windowrulev2 = float, class:^([zZ]en)$, title:.*Bitwarden.*
windowrulev2 = center, class:^([zZ]en)$, title:.*Bitwarden.*
windowrulev2 = size 800 600, class:^([zZ]en)$, title:.*Bitwarden.*

# Kitty
windowrulev2 = float,class:^(kitty)$,title:^(top)$
windowrulev2 = float,class:^(kitty)$,title:^(btop)$
windowrulev2 = float,class:^(kitty)$,title:^(htop)$

# Spotify
windowrulev2 = opacity 0.90 0.90,class:^([Ss]potify)$
windowrulev2 = opacity 0.90 0.90,initialTitle:^(Spotify Free)$
windowrulev2 = opacity 0.90 0.90,initialTitle:^(Spotify Premium)$
windowrulev2 = workspace 3,class:^([Ss]potify)$

# Misc Applications
windowrulev2 = float,class:^(kvantummanager)$
windowrulev2 = float,class:^(qt5ct)$
windowrulev2 = float,class:^(qt6ct)$
windowrulev2 = float,class:^(nwg-look)$
windowrulev2 = float,class:^(org.kde.ark)$
windowrulev2 = float,class:^(org.pulseaudio.pavucontrol)$
windowrulev2 = float,class:^(blueman-manager)$
windowrulev2 = float,class:^(nm-applet)$
windowrulev2 = float,class:^(nm-connection-editor)$
windowrulev2 = float,class:^(org.kde.polkit-kde-authentication-agent-1)$

windowrulev2 = opacity 0.80 0.80,class:^(code-url-handler)$
windowrulev2 = opacity 0.80 0.80,class:^(code-insiders-url-handler)$
windowrulev2 = opacity 0.80 0.80,class:^(org.kde.ark)$
# windowrulev2 = opacity 0.80 0.80,class:^(nwg-look)$
# windowrulev2 = opacity 0.80 0.80,class:^(qt5ct)$
# windowrulev2 = opacity 0.80 0.80,class:^(qt6ct)$
# windowrulev2 = opacity 0.80 0.80,class:^(kvantummanager)$
windowrulev2 = opacity 0.80 0.70,class:^(org.pulseaudio.pavucontrol)$
windowrulev2 = opacity 0.80 0.70,class:^(blueman-manager)$
windowrulev2 = opacity 0.80 0.70,class:^(nm-applet)$
windowrulev2 = opacity 0.80 0.70,class:^(nm-connection-editor)$
windowrulev2 = opacity 0.80 0.70,class:^(org.kde.polkit-kde-authentication-agent-1)$
windowrulev2 = opacity 0.80 0.70,class:^(polkit-gnome-authentication-agent-1)$
windowrulev2 = opacity 0.80 0.70,class:^(org.freedesktop.impl.portal.desktop.gtk)$
windowrulev2 = opacity 0.80 0.70,class:^(org.freedesktop.impl.portal.desktop.hyprland)$

# Android Development
# AVD Emulator: float without borders, centered, reasonable size
windowrulev2 = float, title:^(Emulator)$
windowrulev2 = noborder, title:^(Emulator)$
windowrulev2 = center,title:^(Emulator)$
