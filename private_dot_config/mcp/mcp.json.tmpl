{
  "mcpServers": {
    "codegraph": {
      "description": "Performs code analysis and semantic searches across this local monorepo. Use this server when you need to find function definitions, map codebase architecture, trace dependencies, or search for text symbols inside the workspace root.",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp",
        "--path",
        "${workspaceFolder}"
      ],
      "lifecycle": "keep-alive",
      "exposeResources": true,
      "type": "stdio",
      "directTools": true
    },
    "context7": {
      "description": "live framework docs. Use this server when the user asks for up-to-date documentation, framework APIs, or library guides (e.g., Next.js, Upstash, Tailwind) to avoid generating hallucinated or outdated code syntax.",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "{{ .secrets.context7_api_key }}"
      }
    },
    "exa": {
      "description": "Exa AI web search — real-time web, news, and code search",
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "x-api-key": "{{ .secrets.exa_api_key }}"
      },
      "lifecycle": "lazy",
      "exposeResources": true
    },
    "chrome-devtools": {
      "description": "Browser debugging — inspect elements, take screenshots, debug JavaScript",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "markitdown": {
      "description": "Converts complex files to clean Markdown formats. Use this server when the user provides non-textual documents (such as PDFs, Word files, Excel sheets, HTML strings, or image assets) that must be scraped and parsed into readable text.",
      "command": "uvx",
      "args": [
        "markitdown-mcp@latest"
      ],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "mise": {
      "description": "Manages and inspects the local runtime developer environment. Use this server when you need to discover installed engine versions (Node.js, Python, Ruby), look up active shell environment variables, or execute custom automation workflows defined in tasks.",
      "type": "local",
      "command": "mise",
      "args": [
        "mcp"
      ],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "fal-ai": {
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer $env:FAL_AI_API_KEY"
      },
      "lifecycle": "lazy"
    }
  },

  "imports": [
    "cursor",
    "claude-code",
    "opencode"
  ],
  "settings": {
    "idleTimeout": 10
  }
}
