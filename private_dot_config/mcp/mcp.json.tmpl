{
  "mcpServers": {
    "codegraph": {
      "description": "Performs code analysis and semantic searches across this local monorepo. Use this server when you need to find function definitions, map codebase architecture, trace dependencies, or search for text symbols inside the workspace root.",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp",
        "--path",
        "${workspaceFolder}"
      ],
      "lifecycle": "keep-alive",
      "exposeResources": true,
      "type": "stdio",
      "directTools": true
    },
    "chrome-devtools": {
      "description": "Browser debugging — inspect elements, take screenshots, debug JavaScript",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "markitdown": {
      "description": "Converts complex files to clean Markdown formats. Use this server when the user provides non-textual documents (such as PDFs, Word files, Excel sheets, HTML strings, or image assets) that must be scraped and parsed into readable text.",
      "command": "uvx",
      "args": [
        "markitdown-mcp@latest"
      ],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "fal-ai": {
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer $env:FAL_AI_API_KEY"
      },
      "lifecycle": "lazy"
    }
  },

  "imports": [
    "cursor",
    "claude-code",
    "opencode"
  ],
  "settings": {
    "idleTimeout": 10
  }
}
