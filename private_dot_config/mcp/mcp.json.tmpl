{
  "mcpServers": {
    "codegraph": {
      "description": "Code analysis and search for this monorepo",
      "command": "codegraph",
      "args": ["serve", "--mcp"],
      "lifecycle": "keep-alive",
      "exposeResources": true
    },
    "exa": {
      "description": "Web search and content extraction",
      "url": "https://mcp.exa.ai/mcp",
      "headers": {
        "x-api-key": "{{ .secrets.exa_api_key }}"
      },
      "lifecycle": "lazy",
      "exposeResources": true
    },
    "context7": {
      "description": "Library & framework documentation",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{ .secrets.context7_api_key }}"
      },
      "lifecycle": "keep-alive",
      "exposeResources": true
    },
    "chrome-devtools": {
      "description": "Browser debugging — inspect elements, take screenshots, debug JavaScript",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "markitdown": {
      "description": "Convert documents to Markdown (Office, PDF, HTML, images)",
      "command": "uvx",
      "args": ["markitdown-mcp@latest"],
      "lifecycle": "lazy",
      "exposeResources": false
    },
    "mise": {
      "description": "Connects to mise to manage the local developer environment. Use this server when you need to inspect installed tool versions (Node.js, Python, etc.), view project environment variables, read local configurations, or execute workspace automation tasks via the run_task tool.",
      "type": "local",
      "command": ["mise", "mcp"],
      "lifecycle": "lazy",
      "exposeResources": false
    }
  }
}
