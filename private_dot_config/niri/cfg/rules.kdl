layer-rule {
    match namespace="^noctalia-wallpaper*"
    place-within-backdrop true
}

layer-rule {
    match namespace="^fuzzel$"
    background-effect {
        blur true
    }
}

window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
}

// Global blur for all windows (noctalia recommended)
window-rule {
    background-effect {
        blur true
        xray false
    }
}

// Noctalia surfaces blur
layer-rule {
    match namespace="^noctalia-(bar-[^\"]+|notification|dock|panel|attached-panel|osd)$"
    background-effect {
        xray false
    }
}

// Noctalia settings window
window-rule {
    match app-id="dev.noctalia.Noctalia.Settings"
    open-floating true
    default-column-width { fixed 1080; }
    default-window-height { fixed 920; }
}

window-rule {
    open-floating true

    match app-id="^nemo$"
    match app-id=r#"^org\.gnome\.Nautilus$"#
    match app-id="^cachyos-pi$"
    match app-id=r#"^org\.gnome\.Zenity$"#

    match app-id="Emulator"
    match app-id=r#"dev\.zed\.Zed$"# title=r#"Settings"#
    match app-id=r#"dev\.zed\.Zed$"# title=r#"Project Structure"#
  
    // nwg-look
    match app-id=r#"^nwg-look$"#
    match app-id=r#"^qt6ct$"#

    match app-id=r#"^avdmanager$"#
    match title=r#"AVD|Virtual Device"#

    match title=r#"(?i)Extension.*Bitwarden"#


    default-column-width { fixed 1734; }
    default-window-height { fixed 1024; }
}


window-rule {
    match app-id="^zen$"
    match app-id="^brave-browser$"
    exclude title=r#"(?i)Extension.*Bitwarden"#
    open-maximized-to-edges true
    open-maximized true
    default-column-width { proportion 1.0; }
    open-on-workspace "2"

    background-effect {
        blur true
    }
}

window-rule {
    match app-id="^chromium$"
    open-on-workspace "2"
}

window-rule {
    match app-id="^Alacritty$"
    open-maximized-to-edges true
    open-maximized true
    default-column-width { proportion 1.0; }
    border {
        off
    }
    background-effect {
        blur true
    }
}

window-rule {
    match app-id=r#"^code(-insiders)?$"#
    match app-id=r#"^dev\.zed\.Zed$"#
    match app-id=r#"^zcode$"#
    match app-id=r#"^cursor$"#
    open-on-output "DP-3"

    draw-border-with-background true
    default-column-width { proportion 0.85556; }
    open-on-workspace "1"
    background-effect {
        blur true
    }
}

window-rule {
    match app-id=r#"(?i)^slack$"#
    match app-id="^discord$"
    match app-id="^vesktop$"
    open-on-output "DP-3"
    open-on-workspace "3"
    open-floating true
}


window-rule {
    match app-id="^privateinternetaccess$"
    open-on-output "HDMI-A-1"
}

window-rule {
  // upwork screencast block
  match app-id="^Upwork$"
  block-out-from "screencast"
}

window-rule {
    match app-id="^Bitwarden$"
    block-out-from "screencast"
}

window-rule {
    match app-id=r#"(?i)^slack$"#
    block-out-from "screencast"
}

window-rule {
    match app-id="^vesktop$"
    block-out-from "screencast"
}

window-rule {
    match app-id="^zen$" title=r#"(?i)\bPrivate\b"#
    match app-id="^brave-browser$" title=r#"(?i)\bIncognito\b"#
    block-out-from "screencast"
}

// ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ Game Launchers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Rule order: more specific first, catch-all last

window-rule {
    match app-id="^steam_app_default$"
    open-floating true
    open-on-output "DP-3"
    open-on-workspace "4"
}

window-rule {
    match app-id=r#"^steam_app_\d+$"#
    open-on-output "DP-3"
    open-on-workspace "4"
}

window-rule {
    match app-id="^steam$"
    open-maximized-to-edges true
    open-maximized true
    default-column-width { proportion 1.0; }
    open-on-workspace "4"
}

window-rule {
    match app-id=r#"^net\.lutris\.Lutris$"#
    match app-id="^faugus-launcher$"
    open-floating true
    open-on-workspace "4"
    open-on-output "DP-3"
}


window-rule {
    match app-id="^Heroic$"
    open-maximized-to-edges true
    open-maximized true
    default-column-width { proportion 1.0; }
    open-on-workspace "4"
}

window-rule {
    match app-id="^gamescope$"
    open-on-workspace "4"
}

window-rule {
    match app-id="^Goverlay$"
    open-floating true
    open-on-workspace "4"
}

window-rule {
    match app-id="^protontricks$"
    open-floating true
    open-on-workspace "4"
}

window-rule {
    match app-id=r#"^org\.qbittorrent\.qBittorrent$"#
    open-floating true
    default-column-width { fixed 1734; }
    default-window-height { fixed 1024; }
    default-floating-position x=520 y=252
}
