// ────────────── Named Workspaces ──────────────
// https://niri-wm.github.io/niri/Configuration%3A-Named-Workspaces.html
//
// These persist even when empty and stick to their output.

workspace "1" {
    open-on-output "DP-3"
}

workspace "2" {
    open-on-output "DP-3"
}

workspace "3" {
    open-on-output "DP-3"
}

workspace "4" {
    open-on-output "DP-3"
}

workspace "5"

