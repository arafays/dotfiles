{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  // Active preset name — switches all agent models/skills/MCPs at once
  // Runtime switch: /preset <name>
  "preset": "opencode",
  // Agents to disable globally (not per-preset). Empty = all enabled.
  "disabled_agents": [],
  // Auto-install plugin updates in background. Set false for notification-only.
  "autoUpdate": true,
  // Multiplexer for running specialist agents in separate panes
  "multiplexer": {
    "type": "tmux",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  // Council: multi-LLM voting. Each preset defines councillor models.
  "council": {
    "default_preset": "opencode",
    "presets": {
      "opencode": {
        "deepseek": {
          "model": "opencode-go/deepseek-v4-pro",
          "variant": "high"
        },
        "glm": {
          "model": "opencode-go/glm-5.2",
          "variant": "high"
        },
        "kimi": {
          "model": "opencode-go/kimi-k2.7-code",
          "variant": "high"
        }
      },
      "cheapest": {
        "deepseek": {
          "model": "opencode-go/deepseek-v4-flash",
          "variant": "medium"
        },
        "mimo": {
          "model": "opencode-go/mimo-v2.5",
          "variant": "medium"
        },
        "minimax": {
          "model": "opencode-go/minimax-m2.7",
          "variant": "low"
        }
      },
      "daily": {
        "deepseek": {
          "model": "opencode-go/deepseek-v4-pro",
          "variant": "high"
        },
        "glm": {
          "model": "opencode-go/glm-5.2",
          "variant": "high"
        },
        "kimi": {
          "model": "opencode-go/kimi-k2.7-code",
          "variant": "high"
        }
      }
    }
  },
  // Per-preset agent config: model, variant, skills, and MCPs
  //
  // Built-in MCP names (exact, case-sensitive):
  //   "websearch" — Exa AI web search
  //   "context7"  — up-to-date library documentation
  //   "gh_grep"   — GitHub code search via grep.app (NOT "grep_app")
  //   "codegraph" — local codegraph MCP (user-installed)
  //
  // Skill syntax: ["*"] = all, ["name"] = explicit, ["*","!name"] = exclude
  "presets": {
    "opencode": {
      "orchestrator": {
        "model": "opencode-go/glm-5.2",
        // All skills — orchestrator uses codemap, deepwork, reflect, worktrees,
        // clonedeps, oh-my-opencode-slim directly (not delegated)
        "skills": [
          "*"
        ],
        // All MCPs except context7, gh_app, websearch (librarian handles research)
        "mcps": [
          "*",
          "!context7",
          "!gh_app",
          "!websearch"
        ]
      },
      "oracle": {
        "model": "opencode-go/deepseek-v4-pro",
        "variant": "max",
        // Code review + simplification
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "council": {
        "model": "opencode-go/deepseek-v4-pro",
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": "opencode-go/minimax-m2.7",
        "skills": [],
        // Research agent: web search + docs + GitHub code search
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": "opencode-go/deepseek-v4-flash",
        "skills": [],
        "mcps": [
          "codegraph"
        ]
      },
      "designer": {
        // K2.6 chosen over K2.7 Code — better general vision for UI/screenshots
        "model": "opencode-go/kimi-k2.6",
        "variant": "medium",
        "skills": [
          "agent-browser"
        ],
        "mcps": [
          "codegraph"
        ]
      },
      "fixer": {
        // Fast + cheap — mechanical implementation tasks
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "high",
        "skills": [],
        "mcps": [
          "codegraph"
        ]
      },
      "observer": {
        // Vision-only: screenshots, images, diagrams
        "model": "opencode-go/kimi-k2.6",
        "skills": [],
        "mcps": []
      }
    },
    "cheapest": {
      "orchestrator": {
        "model": "opencode-go/deepseek-v4-flash",
        "skills": [
          "*"
        ],
        "mcps": [
          "*",
          "!context7"
        ]
      },
      "oracle": {
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "low",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "council": {
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": "opencode/north-mini-code-free",
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": "opencode-go/deepseek-v4-flash",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "opencode/big-pickle",
        "skills": [
          "agent-browser"
        ],
        "mcps": []
      },
      "fixer": {
        "model": "opencode-go/deepseek-v4-flash",
        "variant": "high",
        "skills": [],
        "mcps": []
      },
      "observer": {
        "model": "opencode/nemotron-3-ultra-free",
        "skills": [],
        "mcps": []
      }
    },
    "daily": {
      "orchestrator": {
        "model": "opencode-go/glm-5.2",
        "skills": [
          "*"
        ],
        "mcps": [
          "*",
          "!context7",
          "!gh_app",
          "!websearch"
        ]
      },
      "oracle": {
        "model": "opencode-go/deepseek-v4-pro",
        "variant": "high",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "council": {
        "model": "opencode-go/kimi-k2.6",
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "librarian": {
        "model": "opencode-go/minimax-m2.7",
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep",
          "codegraph"
        ]
      },
      "explorer": {
        "model": "opencode-go/deepseek-v4-flash",
        "skills": [],
        "mcps": [
          "codegraph"
        ]
      },
      "designer": {
        "model": "opencode-go/kimi-k2.7-code",
        "variant": "medium",
        "skills": [
          "agent-browser"
        ],
        "mcps": []
      },
      "fixer": {
        "model": "opencode-go/minimax-m3",
        "variant": "high",
        "skills": [],
        "mcps": [
          "codegraph"
        ]
      },
      "observer": {
        "model": "opencode-go/kimi-k2.6",
        "skills": [],
        "mcps": []
      }
    }
  }
}
