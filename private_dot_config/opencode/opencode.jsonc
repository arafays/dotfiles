{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./profile.yaml"
  ],
  "model": "github-copilot/grok-code-fast-1",
  "mcp": {
    "v1": {
      "type": "remote",
      "url": "https://mcp.v1.run/mcp",
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--executable-path",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    },
  },
}
