{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./profile.yaml"
  ],
  "autoupdate": "notify",
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": [
          "plan"
        ]
      }
    ],
    "@tarquinen/opencode-dcp@latest",
    "opencode-vibeguard",
    "oh-my-opencode-slim",
    "opencode-antigravity-auth",
    "opencode-antigravity-image"
  ],
  "lsp": true,
  "default_agent": "opencode-go/deepseek-v4-flash",
  "mcp": {
    "mise": {
      "type": "local",
      "command": [
        "mise",
        "mcp"
      ],
      "enabled": false
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}"
      ],
      "enabled": false
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
