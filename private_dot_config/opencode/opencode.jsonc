{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./profile.yaml"
  ],
  "permission": {
    "git add *": "ask",
    "git reset": "deny",
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": true
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    }
  },
}
