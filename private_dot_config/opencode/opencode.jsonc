{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "./profile.yaml"
  ],
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": [
          "plan"
        ]
      }
    ],
    "@tarquinen/opencode-dcp@latest",
    "opencode-vibeguard",
    "oh-my-opencode-slim"
  ],
  "default_agent": "opencode-go/deepseek-v4-flash",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "permission": {
    "git reset": "deny",
    "sudo": "ask",
    "rm -rf": "ask"
  },
  "mcp": {
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}"
      ],
      "enabled": false
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    },
    "mise": {
      "type": "local",
      "command": [
        "mise",
        "mcp"
      ],
      "enabled": true
    },
    "fal-ai": {
      "type": "remote",
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:FAL_AI_API_KEY}"
      },
      "enabled": false
    }
  },
  "lsp": true
}
