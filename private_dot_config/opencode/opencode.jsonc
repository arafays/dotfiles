{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./profile.yaml"
  ],
  "plugin": [
    "@plannotator/opencode@latest",
  ],
  // "lsp": {
  //   "qmlls": {
  //     "command": [
  //       "/usr/lib/qt6/bin/qmlls",
  //       "-E",
  //       "-I",
  //       "/usr/lib/qt6/qml",
  //       "-I",
  //       "/etc/xdg/quickshell/noctalia-shell"
  //     ],
  //     "extensions": [
  //       ".qml"
  //     ],
  //     "env": {
  //       "QML_IMPORT_PATH": "{env:QML_IMPORT_PATH}:/usr/lib/qt6/qml:/etc/xdg/quickshell/noctalia-shell"
  //     }
  //   }
  // },
  "permission": {
    "git add *": "ask",
    "git reset": "deny",
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest",
        "--api-key",
        "{env:CONTEXT7_API_KEY}",
      ],
      "enabled": true
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false
    },
    // "upwork": {
    //   "type": "local",
    //   "command": [
    //     "uv",
    //     "--directory",
    //     "/home/arafays/upwork-mcp",
    //     "run",
    //     "upwork-mcp"
    //   ],
    //   "enabled": false
    // },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    },
    "fal-ai": {
      "type": "remote",
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:FAL_AI_API_KEY}"
      },
      "enabled": false
    }
  },
}
