{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "./profile.yaml"
  ],
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": [
          "plan",
          "orchestrator"
        ]
      }
    ],
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
      "model": "opencode-go/glm-5.2"
    }
  },
  "permission": {
    "git reset": "deny",
    "sudo": "ask",
    "rm -rf": "ask",
  },
  "mcp": {
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    },
    "mise": {
      "type": "local",
      "command": [
        "mise",
        "mcp"
      ],
      "enabled": false
    },
    "fal-ai": {
      "type": "remote",
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:FAL_AI_API_KEY}"
      },
      "enabled": false
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "lsp": true,
}
