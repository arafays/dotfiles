{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "./profile.yaml"
  ],
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": [
          "plan",
          "sisyphus"
        ]
      }
    ],
    "@tarquinen/opencode-dcp@latest",
    "octto",
    "opencode-vibeguard",
    "oh-my-opencode-slim"
  ],
  "default_agent": "opencode-go/deepseek-v4-flash",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  // "lsp": {
  //   "qmlls": {
  //     "command": [
  //       "/usr/lib/qt6/bin/qmlls",
  //       "-E",
  //       "-I",
  //       "/usr/lib/qt6/qml",
  //       "-I",
  //       "/etc/xdg/quickshell/noctalia-shell"
  //     ],
  //     "extensions": [
  //       ".qml"
  //     ],
  //     "env": {
  //       "QML_IMPORT_PATH": "{env:QML_IMPORT_PATH}:/usr/lib/qt6/qml:/etc/xdg/quickshell/noctalia-shell"
  //     }
  //   }
  // },
  "permission": {
    "git reset": "deny",
    "sudo": "ask",
    "rm -rf": "ask"
  },
  "mcp": {
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false
    },
    // "upwork": {
    //   "type": "local",
    //   "command": [
    //     "uv",
    //     "--directory",
    //     "/home/arafays/upwork-mcp",
    //     "run",
    //     "upwork-mcp"
    //   ],
    //   "enabled": false
    // },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    },
    "mise": {
      "type": "local",
      "command": [
        "mise",
        "mcp",
      ],
      "enabled": false
    },
    "fal-ai": {
      "type": "remote",
      "url": "https://mcp.fal.ai/mcp",
      "headers": {
        "Authorization": "Bearer {env:FAL_AI_API_KEY}"
      },
      "enabled": false
    }
  },
}
