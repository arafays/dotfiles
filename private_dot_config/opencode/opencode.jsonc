{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["./profile.yaml"],
  "autoupdate": "notify",
  "default_agent": "build",
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": ["plan"],
      },
    ],
    "@tarquinen/opencode-dcp@latest",
  ],
  "permission": {
    "bash": {
      "sudo *": "deny",
      "sudo -u *": "deny",
      "doas *": "deny",
      "pkexec *": "deny",
    },
    "read": {
      ".env*": "deny",
    },
  },
  "mcp": {
    "mise": {
      "type": "local",
      "command": ["mise", "mcp"],
      "enabled": false,
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "{env:CHROMIUM_PATH}",
      ],
      "enabled": false,
    },
    "markitdown": {
      "type": "local",
      "command": ["uvx", "markitdown-mcp"],
      "enabled": false,
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },
  "lsp": true,
}
