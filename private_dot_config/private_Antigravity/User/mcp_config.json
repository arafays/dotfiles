{
  "mcpServers": {
    "sequentialthinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"]
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest", "--api-key", "{env:CONTEXT7_API_KEY}"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--executable-path", "{env:CHROMIUM_PATH}"]
    },
    "devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--executablePath", "{env:CHROMIUM_PATH}"]
    },
    "markitdown": {
      "command": "uvx",
      "args": ["markitdown-mcp"]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp"
    }
  }
}