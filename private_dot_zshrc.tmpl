[[ -f ~/.profile ]] && source ~/.profile

export HISTFILE="${ZDOTDIR:-$HOME}/.zsh_history"
export HISTSIZE=50000
export SAVEHIST=50000
export GPG_TTY=$(tty)
export EDITOR="nvim"

unsetopt BEEP
setopt AUTO_CD GLOB_DOTS NOMATCH MENU_COMPLETE EXTENDED_GLOB
setopt INTERACTIVE_COMMENTS INC_APPEND_HISTORY EXTENDED_HISTORY
setopt HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS HIST_VERIFY
setopt HIST_IGNORE_SPACE HIST_FIND_NO_DUPS BANG_HIST

for env_file in ~/.config/environment.d/*.conf; do
  [[ -f "$env_file" ]] && source "$env_file"
done

_cmd_exists() {
  (( ${+commands[$1]} ))
}

[[ -n "$aurhelper" ]] && return
for helper in yay paru; do
  if _cmd_exists "$helper"; then
    export aurhelper="$helper"
    break
  fi
done

_init_starship() {
  # Show system info only in interactive shells
  # if [[ $- == *i* ]] && [[ -z "$TMUX" ]]; then
  #   if _cmd_exists fastfetch; then
  #     fastfetch --logo-type small 2>/dev/null
  #   fi
  # fi
  #
  if _cmd_exists starship; then
    eval "$(starship init zsh)"
  else
    echo "Starship not found. Install it? (y/n)"
    read -r response
    if [[ "$response" == "y" ]]; then
      curl -fsSL https://starship.rs/install.sh | sh -s -- --yes
      eval "$(starship init zsh)"
      export STARSHIP_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/starship"
      export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship/starship.toml"
    fi
  fi
}

_install_tool() {
  local tool="$1"
  local aur_package="$2"
  if [[ -z "$aurhelper" ]]; then
    echo "No AUR helper found. Please install $tool manually."
    return 1
  fi
  echo "Installing $tool using $aurhelper..."
  if $aurhelper -S "$aur_package"; then
    return 0
  else
    echo "Failed to install $tool"
    return 1
  fi
}

_load_completion() {
  local tool="$1"
  local completion_cmd="$2"
  local delay="${3:-3}"
  if ! _cmd_exists "$tool" || [[ -z "$completion_cmd" || "$completion_cmd" == "skip" ]]; then
    return
  fi
  case "$tool" in
    git | docker) ;;
    *)
      zinit wait"$delay" lucid nocd as"completion" for \
        atload"eval \"\$($completion_cmd)\" 2>/dev/null" \
        zdharma-continuum/null
      ;;
  esac
}

_setup_vi_mode() {
  bindkey -v
  export KEYTIMEOUT=1
  bindkey '^H' backward-delete-char
  bindkey '^?' backward-delete-char
  zle-keymap-select() {
    if [[ ${KEYMAP} == vicmd ]]; then echo -ne '\e[1 q'
    else echo -ne '\e[5 q'
    fi
  }
  zle -N zle-keymap-select
}

_init_zinit() {
  local zinit_dir="$HOME/.local/share/zinit/zinit.git"
  if [[ ! -f "$zinit_dir/zinit.zsh" ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$zinit_dir"
  fi
  source "$zinit_dir/zinit.zsh"
}

_setup_essential_tools() {
  local tools=("git" "nvim" "gh" "docker" "bat" "rg" "fzf" "eza")
  local packages=("git" "neovim" "github-cli" "docker" "bat" "ripgrep" "fzf" "eza")
  local completions=("skip" "skip" "gh completion -s zsh" "skip" "bat --completion zsh" "rg --generate=complete-zsh" "fzf --zsh" "skip")
  for i in {1..${#tools[@]}}; do
    local tool="${tools[$i]}"
    local package="${packages[$i]}"
    local completion_cmd="${completions[$i]}"
    if _cmd_exists "$tool"; then
      _load_completion "$tool" "$completion_cmd" "2"
    else
      echo "$tool not found. Install it? (y/n)"
      read -r response
      if [[ "$response" == "y" ]]; then
        _install_tool "$tool" "$package" && _load_completion "$tool" "$completion_cmd" "3"
      fi
    fi
  done
}

_setup_optional_tools() {
  local tools=("warp-cli" "chezmoi")
  local packages=("warp-cli" "chezmoi")
  local completions=("warp-cli generate-completions zsh" "chezmoi completion zsh")
  for i in {1..${#tools[@]}}; do
    if _cmd_exists "${tools[$i]}"; then
      _load_completion "${tools[$i]}" "${completions[$i]}" "3"
    fi
  done
}

_setup_menuselect_bindings() {
  bindkey -M menuselect '?' history-incremental-search-forward
  bindkey -M menuselect '/' history-incremental-search-backward
  if [[ -o menucomplete ]]; then
    bindkey -M menuselect '^h' vi-backward-char
    bindkey -M menuselect '^k' vi-up-line-or-history
    bindkey -M menuselect '^l' vi-forward-char
    bindkey -M menuselect '^j' vi-down-line-or-history
    bindkey -M menuselect '^[[Z' vi-up-line-or-history
  fi
}

_init_plugins() {
  zstyle ':completion:*' menu yes select
  zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
  zmodload zsh/complist
  _comp_options+=(globdots)
  zle_highlight=('paste:none')
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
  zstyle ':fzf-tab:*' use-fzf-default-opts yes
  zstyle ':fzf-tab:*' fzf-preview 'bat --color=always --style=numbers --line-range :500 {}'
  autoload -Uz compinit && compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-$ZSH_VERSION"
  zinit wait lucid for \
    atinit"zicompinit; zicdreplay" \
    zdharma-continuum/fast-syntax-highlighting \
    atload"_zsh_autosuggest_start" \
    zsh-users/zsh-autosuggestions
  zinit wait'1' lucid blockf atpull'zinit creinstall -q .' for zsh-users/zsh-completions
  zinit wait'1' lucid atload"_setup_menuselect_bindings" for Aloxaf/fzf-tab
  zinit wait'2' lucid for MichaelAquilina/zsh-you-should-use
  _setup_essential_tools
  _setup_optional_tools
}

_load_aliases() {
  _cmd_exists zoxide && alias cd='z'
  if _cmd_exists fzf; then
    source <(fzf --zsh)
    alias ff='fzf --preview "bat --style=numbers --color=always {}"'
  fi
  _cmd_exists fd && alias find='fd' && alias f='fd --type f --hidden --follow --exclude .git'
  _cmd_exists rg && alias grep='rg --color=auto --line-number --smart-case --hidden --glob "!.git"'
  if _cmd_exists bat; then
    alias cat='bat --style=plain --color=always --paging=never'
    alias less='bat --style=plain --color=always --paging=always'
  else
    alias cat='cat --show-all --show-control-chars --show-tabs --show-nonprinting'
    alias less='less -R'
  fi
  if _cmd_exists eza; then
    alias ls='eza -lh --icons=auto --group-directories-first'
    alias ll='eza -lha --icons=auto --sort=name --group-directories-first'
    alias l='eza -lh --icons=auto'
    alias la='eza -lha --icons=auto'
    alias ld='eza -lhD --icons=auto'
    alias lt='eza --icons=auto --tree --level=2'
    alias lta='eza --icons=auto --tree --level=3 --all'
    export EZA_COLORS="da=36:di=34:ex=32:fi=0:ln=35:pi=33:so=31"
  fi
  if [[ -n "$aurhelper" ]]; then
    alias un="$aurhelper -Rns"
    alias up="$aurhelper -Syu --noconfirm"
    alias look="$aurhelper -Qs"
    alias search="$aurhelper -Ss"
    alias pc="$aurhelper -Sc"
    alias po="$aurhelper -Qtdq | $aurhelper -Rns -"
    alias pi="$aurhelper -Si"
    alias orphans="$aurhelper -Qtdq"
  fi
  alias ..='cd ..'
  alias ...='cd ../..'
  alias -- -='cd -'
  alias mkdir='mkdir -p'
  alias cp='cp -i'
  alias mv='mv -i'
  alias rm='rm -i'
  alias vim='nvim'
  alias n='nvim'
  alias dev='code-insiders .'
}

_define_functions() {
  fcd() {
    local dir
    dir=$(find . -maxdepth 5 \( -name .git -o -name node_modules -o -name .next -o -name dist \) -prune -o -type d -print 2>/dev/null |
      fzf --height=60% --layout=reverse --preview='eza -la --icons=auto {}' --preview-window=right:60%) && cd "$dir"
  }
  fe() {
    local file
    file=$(fzf --preview='bat --color=always --style=numbers --line-range=:500 {}' --preview-window=right:60%) && ${EDITOR:-nvim} "$file"
  }
  in() {
    [[ $# -eq 0 ]] && return 1
    if _cmd_exists "$aurhelper"; then $aurhelper -S "$@"
    else sudo pacman -S "$@"
    fi
  }
  compress() {
    local archive="$1"; shift
    case "$archive" in
      *.tar.gz) tar -czf "$archive" "$@" ;;
      *.zip) zip -r "$archive" "$@" ;;
      *.7z) 7z a "$archive" "$@" ;;
      *) echo "Unsupported format" ;;
    esac
  }
  extract() {
    local archive="$1"
    case "$archive" in
      *.tar.gz|*.tgz) tar -xzf "$archive" ;;
      *.zip) unzip "$archive" ;;
      *.7z) 7z x "$archive" ;;
      *) echo "Unsupported format" ;;
    esac
  }
  tn() { tmux new-session -A -s "${${$(basename "$PWD")}//[^a-zA-Z0-9_-]/_}" -c "$PWD"; }
  ts() {
    local ses=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf --layout=reverse)
    [[ -n "$ses" ]] && (tmux switch-client -t "$ses" 2>/dev/null || tmux attach-session -t "$ses")
  }
  tk() {
    [[ -n "$1" ]] && tmux kill-session -t "$1" || {
      local ses=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf --layout=reverse)
      [[ -n "$ses" ]] && tmux kill-session -t "$ses"
    }
  }
  tl() { tmux list-sessions; }
  emulator() {
    env -u QT_QPA_PLATFORM -u GDK_BACKEND -u SDL_VIDEODRIVER QT_QPA_PLATFORM=xcb "${ANDROID_HOME:-$HOME/Android/Sdk}/emulator/emulator" "$@"
  }
  _mise_chpwd_hook() {
    _cmd_exists mise || return
    local tools=($(mise list --current 2>/dev/null | awk '{print $1}' | sort -u))
    [[ ${#tools[@]} -eq 0 ]] && return
    typeset -gA _mcl
    for t in $tools; do
      [[ -n "${_mcl[$t]}" ]] && continue
      case "$t" in
        node)
          _cmd_exists npm && zinit wait'1' lucid nocd as"completion" for atload"eval \"\$(npm completion)\" 2>/dev/null" zdharma-continuum/null && _mcl[npm]=1
          _cmd_exists pnpm && zinit wait'1' lucid nocd as"completion" for atload"eval \"\$(pnpm completion zsh)\" 2>/dev/null" zdharma-continuum/null && _mcl[pnpm]=1
          ;;
        python) _cmd_exists uv && zinit wait'1' lucid nocd as"completion" for atload"eval \"\$(uv generate-shell-completion zsh)\" 2>/dev/null" zdharma-continuum/null && _mcl[uv]=1 ;;
        rust) _cmd_exists cargo && zinit wait'1' lucid nocd as"completion" for atload"eval \"\$(rustup completions zsh cargo)\" 2>/dev/null" zdharma-continuum/null && _mcl[cargo]=1 ;;
      esac
    done
  }
}
parufind() {
  local search_term="$1"
  [[ -z "$search_term" ]] && { echo "Usage: parufind <search-term>"; return 1; }

  paru -Ss "$search_term" 2>/dev/null | awk '
    /^[a-z]/ { if (pkg) print pkg " | " desc; pkg=$1; desc="" }
    /^    / { sub(/^    /, ""); desc=$0 }
    END { if (pkg) print pkg " | " desc }
  ' | fzf \
    --ansi \
    --height=80% \
    --layout=reverse \
    --border=rounded \
    --prompt="📦 Select package: " \
    --header="ENTER: Install | ESC: Cancel" \
    --preview='paru -Si {1}' \
    --preview-window=right:60%:wrap \
    --delimiter='\|' \
    --with-nth=1,2 | \
    cut -d '|' -f1 | tr -d ' ' | xargs -ro paru -S
}

parufind-widget() {
  # Use the current buffer as the search term; if empty, don't run.
  [[ -n "$BUFFER" ]] && parufind "$BUFFER"
  zle reset-prompt
}
zle -N parufind-widget
bindkey '^[p' parufind-widget

if [[ "$TERM_PROGRAM" == "vscode"* ]]; then
  _vccmd=$(command -v code-insiders || command -v code)
  [[ -n "$_vccmd" ]] && . "$($_vccmd --locate-shell-integration-path zsh)"
fi

_cmd_exists zoxide && eval "$(zoxide init zsh)"
_cmd_exists gpg-agent && gpg-agent --daemon >/dev/null 2>&1


_init_mise(){
  zinit as="command" lucid from="gh-r" for id-as="usage" jdx/usage
  zinit as="command" lucid from="gh-r" for if='! (( $+commands[mise] ))' id-as="mise" mv="mise* -> mise" atclone="./mise* completion zsh > _mise" atpull="%atclone" jdx/mise

  if (( $+commands[mise] )); then
  eval "$(mise activate zsh)"
  _load_completion "mise" "mise completion zsh" "1"
  fi
}

alias ua-drop-caches="sudo paccache -rk3; $aurhelper -Sc --aur --noconfirm"
alias ua-update-all="export TMPFILE='$(mktemp)'; sudo true; rate-mirrors --save=$TMPFILE arch --max-delay=21600 && sudo mv $TMPFILE /etc/pacman.d/mirrorlist && ua-drop-caches && $aurhelper -Syyu --noconfirm"
alias ua-update-chaotic='export TMPFILE="$(mktemp)"; \
    sudo true; \
    rate-mirrors --save=$TMPFILE chaotic-aur \
      && sudo cp /etc/pacman.d/chaotic-mirrorlist /etc/pacman.d/chaotic-mirrorlist-backup \
      && sudo mv $TMPFILE /etc/pacman.d/chaotic-mirrorlist \
      && yay -Syyu --noconfirm'

_setup_vi_mode
_init_zinit
_init_mise
_init_plugins
_load_aliases
_define_functions
autoload -Uz add-zsh-hook
add-zsh-hook chpwd _mise_chpwd_hook
_init_starship
